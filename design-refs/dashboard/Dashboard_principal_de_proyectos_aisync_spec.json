{
  "name": "AISync Dashboard Redesign",
  "version": "1.0",
  "format": "Implementation spec for VS Code / Claude Code",
  "source_reference_image": "/mnt/data/tablero_principal_de_proyectos_aisync.png",
  "canvas": {
    "width": 1672,
    "height": 941,
    "background": "#F5F8FC"
  },
  "global_rules": {
    "keep_top_ribbon": true,
    "keep_bottom_ribbon": true,
    "style": "clean SaaS light mode",
    "main_goal": "Reduce visual friction, improve scanability, clarify project hierarchy and connected teams."
  },
  "palette": {
    "page_bg": "#F5F8FC",
    "surface": "#FFFFFF",
    "surface_soft": "#F8FBFF",
    "border": "#DDE6F1",
    "text_primary": "#0C1733",
    "text_secondary": "#5C6B82",
    "text_muted": "#8A97AA",
    "navy": "#08172F",
    "blue": "#1F6BFF",
    "blue_dark": "#114FC7",
    "blue_soft": "#EAF3FF",
    "green": "#63C37D",
    "green_soft": "#E9F8EE",
    "green_border": "#BFE7C8",
    "red_soft": "#FFF0F0",
    "red_text": "#C64F4F",
    "chip_border": "#D8E2EE",
    "shadow": "0 10px 30px rgba(12, 23, 51, 0.06)"
  },
  "typography": {
    "font_family": "Inter, system-ui, sans-serif",
    "title_xl": {
      "size": 28,
      "weight": 700,
      "line_height": 1.2
    },
    "title_lg": {
      "size": 18,
      "weight": 700,
      "line_height": 1.3
    },
    "title_md": {
      "size": 16,
      "weight": 600,
      "line_height": 1.3
    },
    "body": {
      "size": 14,
      "weight": 400,
      "line_height": 1.5
    },
    "small": {
      "size": 12,
      "weight": 400,
      "line_height": 1.4
    },
    "button": {
      "size": 14,
      "weight": 600,
      "line_height": 1.2
    }
  },
  "layout": {
    "page_padding": 24,
    "main_grid": {
      "type": "2-column",
      "columns": [
        "1.7fr",
        "1fr"
      ],
      "gap": 24
    },
    "left_column": {
      "sections": [
        "welcome_header",
        "project_accordion_list"
      ]
    },
    "right_column": {
      "sections": [
        "connected_teams_panel"
      ]
    }
  },
  "header": {
    "welcome_title": "Welcome",
    "welcome_subtitle": "Here's an overview of your projects and teams.",
    "center_email": "agustinstefanell@gmail.com",
    "primary_action": {
      "label": "+ New Project",
      "style": "primary blue button"
    },
    "secondary_action": {
      "label": "Sign out",
      "style": "ghost text"
    }
  },
  "accordion_projects": {
    "container_style": {
      "background": "#FFFFFF",
      "border": "1px solid #DDE6F1",
      "radius": 18,
      "shadow": "0 8px 24px rgba(12, 23, 51, 0.05)"
