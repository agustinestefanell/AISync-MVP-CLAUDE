  "components": {
    "accordion_row": {
      "height": 56,
      "radius": 14,
      "padding_x": 20,
      "border": "1px solid #DDE6F1",
      "background": "#FFFFFF"
    },
    "panel_card": {
      "radius": 18,
      "padding": 18,
      "background": "#FFFFFF",
      "border": "1px solid #DDE6F1",
      "shadow": "0 8px 24px rgba(12, 23, 51, 0.05)"
    },
    "type_chip": {
      "radius": 999,
      "padding_x": 10,
      "padding_y": 4,
      "background": "#F8FBFF",
      "border": "1px solid #D8E2EE",
      "text_color": "#6E7B90"
    },
    "status_chip": {
      "radius": 999,
      "padding_x": 12,
      "padding_y": 5
    },
    "primary_button": {
      "height": 40,
      "radius": 10,
      "background": "#1F6BFF",
      "text": "#FFFFFF"
    },
    "secondary_button": {
      "height": 38,
      "radius": 10,
      "background": "#FFFFFF",
      "border": "1px solid #DDE6F1",
      "text": "#4E5D75"
    }
  },
  "implementation_notes": [
    "The redesign should remain visually close to the approved image.",
    "Do not redesign the top or bottom ribbons.",
    "Use a cleaner card system with more white space and clearer grouping.",
    "Project rows should behave like accordions.",
    "The expanded project contains nested team blocks with workspace and agents clearly indented.",
    "Connected Teams should remain a right-side panel with stacked cards.",
    "Preserve the overall content, but improve spacing, alignment, border consistency, and hierarchy."
  ]
}