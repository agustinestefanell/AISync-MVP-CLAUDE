      {
        "avatar": "PB",
        "avatar_color": "#2F80ED",
        "email_primary": "paola.albe.bayo@gmail.com",
        "email_secondary": "paola.albe.bayo@gmail.com",
        "project": "Prueba Usuario 1",
        "badge": {
          "label": "Host",
          "bg": "#EAF3FF",
          "text": "#2F80ED"
