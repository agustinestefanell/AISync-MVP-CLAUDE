        "worker_count": 24,
        "accent": "#2F9C5B"
      }
    ],
    "note": "Este caso es solo la referencia visual del SVG importable en Figma."
  },
  "contract": {
    "literal_contract": [
      "colores exactos definidos en design_tokens.colors",
      "estructura de Team Card",
      "franja superior coloreada de cada Team Card",
      "mismo tamaño de Card para manager, submanager y worker",
      "submarco independiente por Project",
      "jerarquía expresada por posición y conectores",
      "ribbon superior e inferior",
      "barra de controles de Teams Map",
      "comportamiento de pan y zoom",
      "reglas de overflow y truncamiento"
    ],
    "design_intent_only": [
      "posiciones absolutas del mockup",
      "cantidad exacta de Teams mostrados en el ejemplo",
      "distancias exactas entre ramas en el ejemplo",
      "ancho total del canvas del SVG",
      "nombres ficticios y métricas del caso visual"
    ]
  }
}